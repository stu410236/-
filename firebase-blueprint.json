{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user basic info and game progress.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLevelIndex": { "type": "integer", "description": "The highest level the user has reached." },
        "completed": { "type": "boolean" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user documents, keyed by their UID."
    }
  }
}
